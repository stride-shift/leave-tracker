# Auth.js / NextAuth v5
AUTH_SECRET=          # Generate with: npx auth secret
AUTH_GOOGLE_ID=       # Google OAuth Client ID
AUTH_GOOGLE_SECRET=   # Google OAuth Client Secret

# Google Service Account (for Sheets, Calendar, Gmail API)
GOOGLE_SERVICE_ACCOUNT_EMAIL=   # e.g. leave-tracker@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=  # The private key from JSON key file (keep \n escapes)

# Google Sheets
GOOGLE_SHEET_ID=        # Spreadsheet ID from the Google Sheet URL
GOOGLE_SHEET_NAME=LeaveRequests

# Google Calendar
GOOGLE_CALENDAR_ID=     # Shared calendar ID (e.g. xxx@group.calendar.google.com)

# Manager Configuration (comma-separated emails)
MANAGER_EMAILS=boss@company.com,hr@company.com

# App
NEXT_PUBLIC_APP_NAME=Leave Tracker
